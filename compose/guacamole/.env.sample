# compose/guacamole/.env.sample
# Copy values to .env_files/guacamole.env — never commit the real file

# --- Database Credentials ---
# Database user (default: guacamole)
PG_USER=guacamole
# Database name (default: guacamole)
PG_DB=guacamole
# Generate a strong, unique password: openssl rand -hex 24
# NOTE: this must match what the schema was first initialized with — changing it
# after the DB has been created requires also updating the postgres role password.
PG_PASS=

# --- Authentik SSO (OpenID Connect) ---
# Create a public OAuth2/OpenID provider + application (slug 'guacamole') in Authentik,
# with an RS256 signing key and redirect URI https://myremote.mydomain.com/.
# Guacamole uses the implicit flow, so no client secret is needed.
OPENID_AUTHORIZATION_ENDPOINT=https://mysso.mydomain.com/application/o/authorize/
# JWKS is fetched server-side; the internal address avoids NAT hairpin.
OPENID_JWKS_ENDPOINT=http://authentik-server:9000/application/o/<app-slug>/jwks/
OPENID_ISSUER=https://mysso.mydomain.com/application/o/<app-slug>/
OPENID_CLIENT_ID=
OPENID_REDIRECT_URI=https://myremote.mydomain.com/
OPENID_USERNAME_CLAIM_TYPE=preferred_username
OPENID_SCOPE=openid email profile
# Rank openid above the jdbc/database extension so the login page redirects straight
# to the IdP (SSO-first). Without this, jdbc sorts first and the local username/password
# form is shown instead. Break-glass for guacadmin: comment this line out and recreate
# the container — the local login form returns (SSO stays available).
EXTENSION_PRIORITY=openid
