# compose/caddy/Caddyfile
# Caddy reverse proxy config. One site block per public hostname.
# Replace the example domains below with your own.
#
# After ANY edit to this file you MUST force-recreate Caddy (a plain reload
# misses single-file bind-mount changes):
#   docker compose -f compose/caddy/docker-compose.yml up -d --force-recreate caddy

{
    # ACME account email for Let's Encrypt expiry notices. Use your own.
    email you@mydomain.com
}

# --- Authentik (SSO / identity provider) ---
mysso.mydomain.com {
    encode zstd gzip
    reverse_proxy authentik-server:9000
}

# --- Outline (wiki) ---
mywiki.mydomain.com {
    encode zstd gzip
    reverse_proxy outline-app:3000
}

# --- Paperless-ngx (document management) ---
mydocs.mydomain.com {
    encode zstd gzip
    reverse_proxy paperless-webserver:8000
}

# --- Guacamole (remote desktop in the browser) ---
myremote.mydomain.com {
    encode zstd gzip
    reverse_proxy guacamole-app:8080
}

# --- Guacamole anonymous front-end (optional) ---
# Same app as myremote.mydomain.com, reached via a neutral domain so the URL you
# share has no descriptive name in it. This is front-end only; auth still runs
# through Authentik. See compose/ddclient/README.md for the DNS anchor.
myotherdomain.com {
    encode zstd gzip
    reverse_proxy guacamole-app:8080
}

# --- Template: an app protected by Authentik forward-auth ---
# Copy this block for any upstream you want to sit behind SSO. Caddy asks
# Authentik whether the request is authenticated before it reaches the app; an
# unauthenticated request is redirected to the Authentik login page.
#
# Requires a Proxy Provider (mode: forward_single, external host = this URL) +
# Application in Authentik, attached to the embedded outpost.
#
# myapp.mydomain.com {
#     encode zstd gzip
#     route {
#         # Authentik embedded outpost endpoints (login redirect, callback)
#         reverse_proxy /outpost.goauthentik.io/* authentik-server:9000
#         # Ask Authentik if the request is authenticated; 401 -> login redirect
#         forward_auth authentik-server:9000 {
#             uri /outpost.goauthentik.io/auth/caddy
#             copy_headers X-Authentik-Username X-Authentik-Groups X-Authentik-Email X-Authentik-Name X-Authentik-Uid X-Authentik-Jwt X-Authentik-Meta-Jwks X-Authentik-Meta-Outpost X-Authentik-Meta-Provider X-Authentik-Meta-App X-Authentik-Meta-Version
#         }
#         # Authenticated requests reach the app (WebSocket upgrades pass through)
#         reverse_proxy my-app:8080
#     }
# }
#
# NOTE: do NOT add `trust_forward_header` inside forward_auth. It is not a valid
# Caddy subdirective and will crash the whole Caddyfile (takes every site down).
